<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>AR Burger Menu</title>

<script type="module"
src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js">
</script>

<style>
body{
margin:0;
background:#111;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

model-viewer{
width:100%;
height:100vh;
}
</style>
</head>

<body>

<model-viewer
src="burger.glb"
camera-controls
auto-rotate
ar
ar-modes="scene-viewer webxr quick-look"
shadow-intensity="1">
</model-viewer>

</body>
</html>
